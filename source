local function copyAppearance(from, to)
	for _, item in ipairs(from:GetChildren()) do
		if item:IsA("Accessory") or item:IsA("Shirt") or item:IsA("Pants") or item:IsA("BodyColors") then
			item:Clone().Parent = to
		end
	end
	local head = from:FindFirstChild("Head")
	local cloneHead = to:FindFirstChild("Head")
	if head and cloneHead then
		local face = head:FindFirstChildOfClass("Decal")
		if face then face:Clone().Parent = cloneHead end
	end
end

local function assimilate(target)
	local clone = NPC:Clone()
	clone.Parent = workspace
	local targetRoot = target:FindFirstChild("HumanoidRootPart")
	if targetRoot and clone.PrimaryPart then
		clone:SetPrimaryPartCFrame(targetRoot.CFrame)
	end
	copyAppearance(target, clone)
	local ti = target:FindFirstChild("InfectionIndex")
	local ci = clone:FindFirstChild("InfectionIndex")
	if ti then
		if ci then ci.Value = ti.Value
		else
			local ni = Instance.new("IntValue")
			ni.Name = "InfectionIndex"; ni.Value = ti.Value; ni.Parent = clone
		end
	end
	if not clone:FindFirstChild("Infected") then
		local inf = Instance.new("BoolValue"); inf.Name = "Infected"
		inf.Value = true; inf.Parent = clone
	end
	applyAppearance(clone)
	local hum = target:FindFirstChildOfClass("Humanoid")
	if hum then hum.Health = 0 end
	task.delay(0.2, function() if target then target:Destroy() end end)
	local oldAI = clone:FindFirstChild(script.Name)
	if oldAI then oldAI:Destroy() end
	local assim = clone:FindFirstChild("Assimilee")
	if assim then assim.Disabled = false end
end

local INFECT_RADIUS = 12
local function checkProximityInfection()
	if not ACTIVE then return end
	for _, char in ipairs(getAllCharacters()) do
		if char == NPC then continue end
		local charRoot = char:FindFirstChild("HumanoidRootPart")
		local hum = char:FindFirstChild("Humanoid")
		if not charRoot or not hum then continue end
		local infected = char:FindFirstChild("Infected")
		if infected and infected.Value then continue end
		if (charRoot.Position - Root.Position).Magnitude <= INFECT_RADIUS then
			ACTIVE = false
			infectTarget(char)
			assimilate(char)
			task.wait(0.5)
			ACTIVE = true
		end
	end
end

local function congaMove(center, index)
	local angle = tick() + index
	return center.Position + Vector3.new(math.cos(angle)*8, 0, math.sin(angle)*8)
end

local function getWalkSpeed(char)
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	return hum and hum.WalkSpeed or 16
end

local JUMP_Y_THRESHOLD = 2.5
local function tryJumpToTarget(targetRoot)
	local yDiff = targetRoot.Position.Y - Root.Position.Y
	if yDiff > JUMP_Y_THRESHOLD then
		local gravity = workspace.Gravity
		local power = math.sqrt(2 * gravity * yDiff) * (Humanoid.HipHeight + 1)
		Humanoid.JumpPower = math.clamp(power, 50, 500)
		Humanoid.Jump = true
	end
end

