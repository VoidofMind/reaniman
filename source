local RunService = game:GetService("RunService")

local character  = script.Parent
local humanoid   = character:WaitForChild("Humanoid")
local rootPart   = character:WaitForChild("HumanoidRootPart")
local torso      = character:WaitForChild("Torso")

local RUN_SPEED  = 25

local animFolder = character:WaitForChild("Animations")
local anims = {
	Idle = require(animFolder:WaitForChild("Idle")),
	Walk = require(animFolder:WaitForChild("Walk")),
	Run  = animFolder:FindFirstChild("Run")  and require(animFolder.Run),
	Jump = require(animFolder:WaitForChild("Jump")),
	Fall = require(animFolder:WaitForChild("Fall")),
}

local currentAnim = nil
local animTime    = 0
local defaultC0s  = {}

local joints = {
	HumanoidRootPart_Torso  = rootPart:FindFirstChild("RootJoint"),
	Torso_Head              = torso:FindFirstChild("Neck"),
	["Torso_Left Arm"]      = torso:FindFirstChild("Left Shoulder"),
	["Torso_Right Arm"]     = torso:FindFirstChild("Right Shoulder"),
	["Torso_Left Leg"]      = torso:FindFirstChild("Left Hip"),
	["Torso_Right Leg"]     = torso:FindFirstChild("Right Hip"),
}

for name, motor in pairs(joints) do
	if motor then defaultC0s[name] = motor.C0 end
end

local function playAnimation(anim)
	if currentAnim == anim then return end
	currentAnim = anim
	animTime    = 0
end

local function lerpCFrame(a, b, t) return a:Lerp(b, t) end

RunService.Heartbeat:Connect(function(dt)
	local velocity        = rootPart.Velocity
	local horizontalSpeed = Vector3.new(velocity.X, 0, velocity.Z).Magnitude

	if humanoid.FloorMaterial == Enum.Material.Air then
		if velocity.Y > 0 then playAnimation(anims.Jump)
		else                   playAnimation(anims.Fall) end
	else
		if horizontalSpeed >= RUN_SPEED and anims.Run then
			playAnimation(anims.Run)
		elseif horizontalSpeed > 0.1 then
			playAnimation(anims.Walk)
		else
			playAnimation(anims.Idle)
		end
	end

	if not currentAnim then return end
	local keyframes = currentAnim._Keyframes
	if not keyframes then return end

	animTime += dt
	local duration = keyframes[#keyframes].Time
	if animTime > duration then animTime = animTime % duration end

	local kf1, kf2 = keyframes[1], keyframes[#keyframes]
	for i = 1, #keyframes - 1 do
		if keyframes[i].Time <= animTime and keyframes[i+1].Time >= animTime then
			kf1 = keyframes[i]; kf2 = keyframes[i+1]; break
		end
	end

	local alpha = (animTime - kf1.Time) / math.max(kf2.Time - kf1.Time, 0.001)
	for jointName, c1 in pairs(kf1.CFrames) do
		local motor = joints[jointName]
		if motor and defaultC0s[jointName] then
			local c2 = kf2.CFrames[jointName] or c1
			motor.C0 = defaultC0s[jointName] * lerpCFrame(c1, c2, alpha)
		end
	end
end)
]]
	ReAnimator.Parent = ReAniman

