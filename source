local function getAllCharacters()
	local chars = {}
	for _, player in ipairs(Players:GetPlayers()) do
		if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
			table.insert(chars, player.Character)
		end
	end
	for _, model in ipairs(workspace:GetChildren()) do
		if model:IsA("Model") and model:FindFirstChild("Humanoid") and model ~= NPC then
			table.insert(chars, model)
		end
	end
	return chars
end

local function getInfectionValue(char)
	local val = char:FindFirstChild("InfectionIndex")
	return val and val.Value or nil
end

local function getInfectionLeader()
	local lowest, leader = math.huge, nil
	for _, char in ipairs(getAllCharacters()) do
		local val = getInfectionValue(char)
		if val and val < lowest then lowest = val; leader = char end
	end
	return leader
end

local function getNearestTarget()
	local nearest, dist = nil, 9999999
	for _, char in ipairs(getAllCharacters()) do
		if char ~= NPC and char:FindFirstChild("HumanoidRootPart") then
			local infected = char:FindFirstChild("Infected")
			if not infected or not infected.Value then
				local d = (char.HumanoidRootPart.Position - Root.Position).Magnitude
				if d < dist then dist = d; nearest = char end
			end
		end
	end
	return nearest
end

local NPC_ACCESSORIES = {}
for _, child in ipairs(NPC:GetChildren()) do
	if child:IsA("Accessory") and (child.Name == "Faceplate" or child.Name == "Guard") then
		table.insert(NPC_ACCESSORIES, child)
	end
end
local NPC_SHIRT      = NPC:FindFirstChildOfClass("Shirt")
local NPC_PANTS      = NPC:FindFirstChildOfClass("Pants")
local NPC_BODYCOLORS = NPC:FindFirstChildOfClass("BodyColors")

local function applyAppearance(char)
	for _, child in ipairs(char:GetChildren()) do
		if child:IsA("Accessory") then
			local handle = child:FindFirstChild("Handle")
			if handle then
				local att = handle:FindFirstChildOfClass("Attachment")
				if att and (att.Name == "HatAttachment" or att.Name == "HairAttachment"
					or att.Name == "FaceFrontAttachment" or att.Name == "FaceCenterAttachment") then
					child:Destroy()
				end
			end
		end
	end
	for _, child in ipairs(char:GetChildren()) do
		if child:IsA("Shirt") or child:IsA("Pants") then child:Destroy() end
	end
	for _, acc in ipairs(NPC_ACCESSORIES) do acc:Clone().Parent = char end
	if NPC_SHIRT  then NPC_SHIRT:Clone().Parent  = char end
	if NPC_PANTS  then NPC_PANTS:Clone().Parent  = char end
	local bc = char:FindFirstChildOfClass("BodyColors")
	if not bc then
		bc = NPC_BODYCOLORS and NPC_BODYCOLORS:Clone() or Instance.new("BodyColors")
		bc.Parent = char
	end
	for _, prop in ipairs({"HeadColor3","TorsoColor3","LeftArmColor3","RightArmColor3","LeftLegColor3","RightLegColor3"}) do
		local c = bc[prop]
		bc[prop] = Color3.fromRGB(math.floor(c.R*255), 255, math.floor(c.B*255))
	end
end

