local npc       = script.Parent
local humanoid  = npc:WaitForChild("Humanoid")
local rootPart  = npc:WaitForChild("HumanoidRootPart")

local STUCK_THRESHOLD = 0.5
local STUCK_TIME      = 2
local RAY_DISTANCE    = 5
local LEDGE_CHECK_DIST = 6

local lastPos  = rootPart.Position
local timeStuck = 0

local function checkEnvironment()
	local fwd       = rootPart.CFrame.LookVector
	local origin    = rootPart.Position

	local wallRay   = Ray.new(origin, fwd * RAY_DISTANCE)
	local hitWall   = workspace:FindPartOnRayWithIgnoreList(wallRay, {npc})
	if hitWall then return true end

	local ledgeOrigin = origin + fwd * 3
	local ledgeRay    = Ray.new(ledgeOrigin, Vector3.new(0, -LEDGE_CHECK_DIST, 0))
	local hitFloor    = workspace:FindPartOnRayWithIgnoreList(ledgeRay, {npc})
	if not hitFloor then return true end

	return false
end

while task.wait(0.5) do
	if humanoid.MoveDirection.Magnitude > 0 then
		if checkEnvironment() then humanoid.Jump = true end

		local distanceMoved = (rootPart.Position - lastPos).Magnitude
		if distanceMoved < STUCK_THRESHOLD then
			timeStuck += 0.5
		else
			timeStuck = 0
		end

		if timeStuck >= STUCK_TIME then
			humanoid.Jump = true
			timeStuck = 0
		end

		lastPos = rootPart.Position
	else
		timeStuck = 0
		lastPos   = rootPart.Position
	end
end
]]
